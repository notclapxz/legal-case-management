## 🛠️ Mantenimiento de la Base de Datos

### Procedimientos de Limpieza

```sql
-- Función para limpiar logs antiguos
CREATE OR REPLACE FUNCTION limpiar_logs_antiguos(dias integer DEFAULT 90)
RETURNS integer AS $$
DECLARE
  registros_eliminados integer;
BEGIN
  DELETE FROM actividad_log 
  WHERE created_at < NOW() - (dias || ' days')::interval;
  
  GET DIAGNOSTICS registros_eliminados = ROW_COUNT;
  
  RETURN registros_eliminados;
END;
$$ LANGUAGE plpgsql;

-- Programar limpieza automática (requiere pg_cron extension)
-- SELECT cron.schedule('0 2 * * 0', 'SELECT limpiar_logs_antiguos(90);');
```

### Backup y Recovery

```sql
-- Procedimiento de backup point-in-time
-- 1. Crear backup antes de cambios importantes
CREATE TABLE casos_backup_YYYYMMDD AS TABLE casos;
CREATE TABLE notas_backup_YYYYMMDD AS TABLE notas;
-- ... otras tablas

-- 2. Para revertir cambios si es necesario
TRUNCATE TABLE casos;
INSERT INTO casos SELECT * FROM casos_backup_YYYYMMDD;

-- Procedimiento de validación de integridad referencial
SELECT 
  'casos_notas' as tabla,
  COUNT(*) as total_registros,
  COUNT(c.id) as registros_con_referencia_valida
FROM notas n
LEFT JOIN casos c ON n.caso_id = c.id
UNION ALL
SELECT 
  'casos_pagos' as tabla,
  COUNT(*) as total_registros,
  COUNT(c.id) as registros_con_referencia_valida
FROM pagos p
LEFT JOIN casos c ON p.caso_id = c.id;
```

