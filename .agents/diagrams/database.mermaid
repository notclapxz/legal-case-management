## 🚀 Performance Optimizations

### Índices Compuestos para Consultas Frecuentes

```sql
-- Para dashboard de casos activos
CREATE INDEX idx_dashboard_casos ON casos(estado, created_at DESC, abogado_asignado_id)
  WHERE estado = 'Activo';

-- Para búsquedas de casos
CREATE INDEX idx_busqueda_casos ON casos(cliente, patrocinado, expediente)
  WHERE estado = 'Activo';

-- Para calendario de eventos
CREATE INDEX idx_calendario_eventos ON eventos(fecha_evento, completado, caso_id)
  WHERE fecha_evento >= CURRENT_DATE;

-- Para notas por caso con orden de creación
CREATE INDEX idx_notas_caso_creado ON notas(caso_id, created_at DESC);

-- Para pagos por caso y fecha
CREATE INDEX idx_pagos_caso_fecha ON pagos(caso_id, fecha_pago DESC);
```

### Vistas Materializadas para Reporting

```sql
-- Vista materializada para dashboard de abogados
CREATE MATERIALIZED VIEW dashboard_abogados AS
SELECT 
  p.id as abogado_id,
  p.nombre_completo,
  p.rol,
  COUNT(DISTINCT c.id) as total_casos,
  COUNT(DISTINCT CASE WHEN c.estado = 'Activo' THEN c.id END) as casos_activos,
  COUNT(DISTINCT CASE WHEN c.estado_caso = 'Ganado' THEN c.id END) as casos_ganados,
  COUNT(DISTINCT CASE WHEN c.estado_caso = 'Perdido' THEN c.id END) as casos_perdidos,
  COALESCE(SUM(CASE WHEN c.estado = 'Activo' THEN c.monto_total END), 0) as valor_activo,
  COALESCE(SUM(pag.monto), 0) as total_cobrado
FROM profiles p
LEFT JOIN casos c ON p.id = c.abogado_asignado_id
LEFT JOIN pagos pag ON c.id = pag.caso_id
WHERE p.rol IN ('Abogado', 'Admin') AND p.activo = true
GROUP BY p.id, p.nombre_completo, p.rol;

-- Índice único para refresh
CREATE UNIQUE INDEX idx_dashboard_abogados_unique ON dashboard_abogados(abogado_id);

-- Función para refrescar la vista
CREATE OR REPLACE FUNCTION refresh_dashboard_abogados()
RETURNS void AS $$
BEGIN
  REFRESH MATERIALIZED VIEW dashboard_abogados;
END;
$$ LANGUAGE plpgsql;
```

---

## 🔍 Triggers y Funciones Avanzadas

### Trigger para Actualizar Campos Calculados

```sql
-- Función para actualizar monto pendiente
CREATE OR REPLACE FUNCTION actualizar_monto_pendiente()
RETURNS TRIGGER AS $$
BEGIN
  -- Calcular total pagado para el caso
  DECLARE total_pagado numeric;
  SELECT COALESCE(SUM(monto), 0) INTO total_pagado
  FROM pagos
  WHERE caso_id = NEW.caso_id;
  
  -- Actualizar monto pendiente
  NEW.monto_pendiente := COALESCE(NEW.monto_total, 0) - total_pagado;
  
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Trigger para pagos
CREATE TRIGGER trigger_actualizar_monto_pendiente
  AFTER INSERT OR UPDATE OR DELETE ON pagos
  FOR EACH ROW
  EXECUTE FUNCTION actualizar_monto_pendiente();
```

### Trigger para Validación de Reglas de Negocio

```sql
-- Función para validar estado del caso
CREATE OR REPLACE FUNCTION validar_estado_caso()
RETURNS TRIGGER AS $$
DECLARE
  tiene_pagos boolean;
BEGIN
  -- Verificar si hay pagos registrados
  SELECT EXISTS(
    SELECT 1 FROM pagos 
    WHERE caso_id = NEW.id
    LIMIT 1
  ) INTO tiene_pagos;
  
  -- Si tiene pagos y se intenta cambiar a estado 'Inactivo'
  IF NEW.estado = 'Inactivo' AND tiene_pagos AND OLD.estado = 'Activo' THEN
    RAISE EXCEPTION 'No se puede archivar un caso con pagos registrados. Elimine los pagos primero.';
  END IF;
  
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_validar_estado_caso
  BEFORE UPDATE OF estado ON casos
  FOR EACH ROW
  EXECUTE FUNCTION validar_estado_caso();
```

---

## 📊 Estadísticas y Monitoreo

### Estadísticas Automáticas

```sql
-- Extension para estadísticas
CREATE EXTENSION IF NOT EXISTS pg_stat_statements;

-- Query para obtener top 10 consultas más lentas
SELECT 
  query,
  calls,
  total_time,
  mean_time,
  rows
FROM pg_stat_statements
ORDER BY mean_time DESC
LIMIT 10;

-- Estadísticas de uso de la aplicación
SELECT 
  schemaname,
  tablename,
  seq_scan,
  seq_tup_read,
  idx_scan,
  idx_tup_fetch,
  n_tup_ins,
  n_tup_upd,
  n_tup_del
FROM pg_stat_user_tables
WHERE schemaname = 'public'
ORDER BY n_tup_ins + n_tup_upd + n_tup_del DESC;
```

### Monitoring de Conexiones

```sql
-- View para monitorear conexiones activas
CREATE VIEW conexiones_activas AS
SELECT 
  pid,
  usename,
  application_name,
  client_addr,
  state,
  backend_start,
  query_start,
  state_change,
  query
FROM pg_stat_activity
WHERE state = 'active'
ORDER BY backend_start;
```

